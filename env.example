# ==============================================================================
# BABY BUDDY - ENVIRONMENT CONFIGURATION (env.example)
# ==============================================================================
# This file serves as a reference for all necessary environment variables 
# required to run Baby Buddy in a production containerized environment. 
# ==============================================================================

# ------------------------------------------------------------------------------
# SYSTEM & DJANGO CORE SETTINGS
# ------------------------------------------------------------------------------

# DJANGO_SETTINGS_MODULE
# Tells Django which settings profile to use. For our raw Python container execution, 
# this MUST be set to the production settings file.
DJANGO_SETTINGS_MODULE="babybuddy.settings.production"

# SECRET_KEY
# CRITICAL SECURITY VARIABLE. Used by Django for cryptographic signing of sessions.
# MUST be a long, random string, un this to generate the SECRET_KEY: openssl rand -base64 48.
# In this cluster, this is stored in Bitwarden and injected via ExternalSecrets.
SECRET_KEY="replace-this-with-a-very-long-secure-random-string"

# TZ (Time Zone)
# The timezone for the application container. Crucial for accurate feeding and sleep logs.
# Use standard tz database names (e.g., America/Los_Angeles, Europe/London).
TZ="America/Los_Angeles"

# ------------------------------------------------------------------------------
# ROUTING & PROXY SECURITY
# ------------------------------------------------------------------------------

# ALLOWED_HOSTS
# A comma-separated list of host/domain names that this site can serve. 
# Because Traefik handles our actual external routing, filtering, and TLS termination 
# at the edge of the cluster, it is safe to set this to "*" to allow internal proxying.
ALLOWED_HOSTS="*"

# CSRF_TRUSTED_ORIGINS
# CRITICAL for Reverse Proxies (Traefik). Without this, Django will reject POST requests 
# (like logging into the admin panel) and throw a "403 Forbidden" or "Bad Gateway" error.
# Must include the exact scheme (https://) and your routing domain.
CSRF_TRUSTED_ORIGINS="https://babybuddy.yourdomain.com"

# ------------------------------------------------------------------------------
# DATABASE CONNECTION (CloudNativePG / PostgreSQL)
# ------------------------------------------------------------------------------

# DB_ENGINE
# Switches the Baby Buddy application away from its default SQLite implementation 
# over to our High Availability PostgreSQL backend.
DB_ENGINE="django.db.backends.postgresql"

# DB_HOST
# The internal Kubernetes service name or IP address of your database.
# For CNPG deployments, this is the automatic "-rw" (Read/Write) service generated 
# by the cluster topology.
DB_HOST="babybuddy-db-rw"

# DB_PORT
# The port PostgreSQL is listening on. (Standard: 5432)
DB_PORT="5432"

# DB_NAME
# The name of the database created for the application during CNPG bootstrap.
DB_NAME="babybuddy"

# DB_USER
# The database user with read/write permissions to DB_NAME.
DB_USER="babybuddy"

# DB_PASSWORD
# The password for the DB_USER. 
# Do NOT store the actual password here. This should only exist in Bitwarden 
# and be injected securely via the ClusterSecretStore.
# Run this to generate the DB_PASSWORD: openssl rand -base64 48
DB_PASSWORD="your-secure-db-password"

