{
  "name": "babybuddy",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    },
    "ghcr.io/devcontainers-contrib/features/gulp-cli:2": {},
    "ghcr.io/devcontainers-contrib/features/apt-packages:1": {
      "packages": "gettext,libpq-dev"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "batisteo.vscode-django",
        "donjayamanne.python-environment-manager",
        "mhutchie.git-graph",
        "mrorz.language-gettext",
        "ms-python.black-formatter",
        "ms-python.python",
        "samuelcolvin.jinjahtml"
      ],
      "settings": {
        "[python]": {
          "defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
          "editor": {
            "defaultFormatter": "ms-python.black-formatter"
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "runArgs": ["--name", "babybuddy"],
  "containerEnv": {
    "DJANGO_SETTINGS_MODULE": "babybuddy.settings.development",
    "BB_PORT": "8282"
  },
  "postCreateCommand": "pip install uv && uv sync && npm install --include=dev && npx lefthook install && gulp build && gulp migrate",
  "postAttachCommand": "gulp",
  "forwardPorts": [8282],
  "portsAttributes": {
    "8282": {
      "label": "Baby Buddy",
      "onAutoForward": "notify"
    }
  }
}
